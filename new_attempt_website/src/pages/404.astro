---
import Site from '../layouts/Site.astro';
---
<Site title="Not Found">
  <div class="flex flex-col items-center justify-center min-h-[60vh] px-5 text-center">
    <p class="font-serif text-5xl mb-6" style="color: var(--color-border)">404</p>
    <h1 class="font-serif text-xl mb-3" style="color: var(--color-heading)">Page not found</h1>
    <p class="font-serif italic mb-8" style="color: var(--color-subtle)">
      This page doesn't exist, or has moved.
    </p>
    <a href="/" class="font-sans text-sm link" style="color: var(--color-subtle)">
      ← Back home
    </a>
  </div>
</Site>
