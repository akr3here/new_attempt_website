---
import Site from '../layouts/Site.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { sortByDate, filterDrafts, formatDate } from '../lib/utils';
import { SITE } from '../lib/config';

const allWritings = await getCollection('writings');
const writings = sortByDate(filterDrafts(allWritings)).slice(0, 5);

const allLogs = await getCollection('logs');
const logs = sortByDate(filterDrafts(allLogs)).slice(0, 3);
---

<Site>
  <!-- Hero: just text, no distractions -->
  <section class="px-5 pt-20 pb-16 md:pt-28 md:pb-20">
    <div class="max-w-2xl mx-auto">
      <h1 class="font-serif text-3xl md:text-4xl font-semibold tracking-tight leading-tight mb-6"
          style="color: var(--color-heading)">
        {SITE.name}
      </h1>
      <p class="font-serif text-lg italic leading-relaxed max-w-lg" style="color: var(--color-subtle)">
        {SITE.description}
      </p>
    </div>
  </section>

  <!-- Recent Writings -->
  <section class="px-5 pb-16">
    <div class="max-w-2xl mx-auto">
      <div class="flex items-center justify-between mb-2">
        <h2 class="font-sans text-xs uppercase tracking-widest" style="color: var(--color-muted)">
          Recent Writing
        </h2>
        <a href="/writings"
           class="font-sans text-xs uppercase tracking-widest link"
           style="color: var(--color-muted)">
          All →
        </a>
      </div>
      <hr class="divider mb-0" />

      {writings.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.slug}
          tags={post.data.tags}
          collection="writings"
        />
      ))}
    </div>
  </section>

  <!-- Recent Logs -->
  {logs.length > 0 && (
    <section class="px-5 pb-20">
      <div class="max-w-2xl mx-auto">
        <div class="flex items-center justify-between mb-2">
          <h2 class="font-sans text-xs uppercase tracking-widest" style="color: var(--color-muted)">
            Recent Logs
          </h2>
          <a href="/logs"
             class="font-sans text-xs uppercase tracking-widest link"
             style="color: var(--color-muted)">
            All →
          </a>
        </div>
        <hr class="divider mb-0" />

        {logs.map(log => (
          <PostCard
            title={log.data.title}
            date={log.data.date}
            slug={log.slug}
            tags={log.data.tags}
            collection="logs"
          />
        ))}
      </div>
    </section>
  )}
</Site>
