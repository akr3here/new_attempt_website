---
import Site from '../../layouts/Site.astro';
import PostCard from '../../components/PostCard.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';
import { sortByDate, filterDrafts, groupByYear } from '../../lib/utils';

const allWritings = await getCollection('writings');
const writings = sortByDate(filterDrafts(allWritings));
const byYear = groupByYear(writings);
const years = Array.from(byYear.keys()).sort((a, b) => Number(b) - Number(a));
---

<Site title="Writings" description="Essays, essays, and long-form thinking.">
  <PageHeader
    title="Writings"
    description="Essays and long-form thinking. Ideas I return to, questions I can't shake."
  />

  <div class="px-5 pb-20">
    <div class="max-w-2xl mx-auto">
      {years.map(year => (
        <div class="mb-8">
          <p class="font-sans text-xs uppercase tracking-widest mb-0 py-4"
             style="color: var(--color-muted)">
            {year}
          </p>
          {byYear.get(year)!.map(post => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.slug}
              tags={post.data.tags}
              collection="writings"
            />
          ))}
        </div>
      ))}

      {writings.length === 0 && (
        <p class="font-serif italic py-8" style="color: var(--color-subtle)">
          Nothing here yet.
        </p>
      )}
    </div>
  </div>
</Site>
