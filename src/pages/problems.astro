---
import { getCollection } from 'astro:content';
import Site from '../layouts/Site.astro';
import PageHeader from '../components/PageHeader.astro';

const allProblems = await getCollection('problems');

const problems = allProblems
  .map(entry => ({ ...entry.data, slug: entry.id }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const open = problems.filter(p => !p.solved);
const solved = problems.filter(p => p.solved);
---

<Site title="Problems" description="Problems I'm thinking through — defined, tracked, and eventually solved.">
  <PageHeader title="Problems" description="Define the problem clearly enough and the solution often reveals itself." />

  <div class="max-w-2xl mx-auto space-y-12">

    {open.length > 0 && (
      <section>
        <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-4 font-sans">
          Open · {open.length}
        </h2>
        <ul class="space-y-3">
          {open.map(problem => (
            <li class="group flex items-start justify-between gap-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-5 py-4 transition-colors hover:border-[var(--color-muted)]">
              <div class="flex-1 min-w-0">
                <p class="font-serif font-semibold text-[var(--color-heading)] leading-snug mb-1">
                  {problem.title}
                </p>
                <p class="text-sm text-[var(--color-muted)] leading-relaxed">
                  {problem.description}
                </p>
                {problem.tags && problem.tags.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1.5">
                    {problem.tags.map(tag => (
                      <span class="text-xs font-sans text-[var(--color-muted)] border border-[var(--color-border)] rounded px-1.5 py-0.5">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
              <span class="mt-0.5 shrink-0 inline-flex items-center gap-1.5 text-xs font-sans font-medium text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-950/40 border border-amber-200 dark:border-amber-800 rounded-full px-2.5 py-1">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
                Open
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {solved.length > 0 && (
      <section>
        <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-4 font-sans">
          Solved · {solved.length}
        </h2>
        <ul class="space-y-3">
          {solved.map(problem => (
            <li class="group flex items-start justify-between gap-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-5 py-4 opacity-75 transition-opacity hover:opacity-100">
              <div class="flex-1 min-w-0">
                <p class="font-serif font-semibold text-[var(--color-heading)] leading-snug mb-1">
                  {problem.title}
                </p>
                <p class="text-sm text-[var(--color-muted)] leading-relaxed">
                  {problem.description}
                </p>
                {problem.tags && problem.tags.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1.5">
                    {problem.tags.map(tag => (
                      <span class="text-xs font-sans text-[var(--color-muted)] border border-[var(--color-border)] rounded px-1.5 py-0.5">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
              <span class="mt-0.5 shrink-0 inline-flex items-center gap-1.5 text-xs font-sans font-medium text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-950/40 border border-emerald-200 dark:border-emerald-800 rounded-full px-2.5 py-1">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                Solved
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}

  </div>
</Site>
