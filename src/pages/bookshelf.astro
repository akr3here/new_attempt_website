---
import Site from '../layouts/Site.astro';
import PageHeader from '../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const booksData = await getCollection('bookshelf');
const books = booksData.sort((a, b) => {
  if (!a.data.date || !b.data.date) return 0;
  return b.data.date.getTime() - a.data.date.getTime();
});

const reading = books.filter(b => b.data.status === 'reading');
const read = books.filter(b => b.data.status === 'read');
const wantToRead = books.filter(b => b.data.status === 'want-to-read');

function stars(n?: number) {
  if (!n) return '';
  return '★'.repeat(n) + '☆'.repeat(5 - n);
}
---

<Site title="Bookshelf" description="Books I've read and loved.">
  <PageHeader
    title="Bookshelf"
    description="Books I've read, am reading, and want to read. Annotations where I have them."
  />

  <div class="px-5 pb-20">
    <div class="max-w-3xl mx-auto">

      {reading.length > 0 && (
        <section class="mb-12">
          <h2 class="font-sans text-xs uppercase tracking-widest mb-0 pb-3 border-b"
              style="color: var(--color-muted); border-color: var(--color-border)">
            Currently Reading
          </h2>
          <div class="space-y-0">
            {reading.map(book => (
              <div class="py-4 border-b" style="border-color: var(--color-border)">
                <div class="flex items-baseline justify-between gap-4">
                  <div>
                    <span class="font-serif text-base" style="color: var(--color-heading)">{book.data.title}</span>
                    <span class="font-sans text-sm ml-2" style="color: var(--color-muted)">by {book.data.author}</span>
                  </div>
                </div>
                {book.data.note && (
                  <p class="font-serif text-sm italic mt-2 leading-relaxed" style="color: var(--color-subtle)">
                    {book.data.note}
                  </p>
                )}
                {book.data.tags && book.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-2">
                    {book.data.tags.map(tag => (
                      <a href={`/tags/${tag}`} class="tag">{tag}</a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {read.length > 0 && (
        <section class="mb-12">
          <h2 class="font-sans text-xs uppercase tracking-widest mb-0 pb-3 border-b"
              style="color: var(--color-muted); border-color: var(--color-border)">
            Read
          </h2>
          <div class="space-y-0">
            {read.map(book => (
              <div class="py-4 border-b" style="border-color: var(--color-border)">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <span class="font-serif text-base" style="color: var(--color-heading)">{book.data.title}</span>
                    <span class="font-sans text-sm ml-2" style="color: var(--color-muted)">by {book.data.author}</span>
                    {book.data.year && (
                      <span class="font-sans text-xs ml-1" style="color: var(--color-muted)">({book.data.year})</span>
                    )}
                    {book.data.note && (
                      <p class="font-serif text-sm italic mt-1.5 leading-relaxed" style="color: var(--color-subtle)">
                        {book.data.note}
                      </p>
                    )}
                    {book.data.tags && book.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2 mt-2">
                        {book.data.tags.map(tag => (
                          <a href={`/tags/${tag}`} class="tag">{tag}</a>
                        ))}
                      </div>
                    )}
                  </div>
                  {book.data.rating && (
                    <span class="font-mono text-xs shrink-0" style="color: var(--color-muted)"
                          title={`${book.data.rating}/5`}>
                      {stars(book.data.rating)}
                    </span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {wantToRead.length > 0 && (
        <section>
          <h2 class="font-sans text-xs uppercase tracking-widest mb-0 pb-3 border-b"
              style="color: var(--color-muted); border-color: var(--color-border)">
            Want to Read
          </h2>
          <div class="space-y-0">
            {wantToRead.map(book => (
              <div class="py-3 border-b" style="border-color: var(--color-border)">
                <span class="font-serif text-sm" style="color: var(--color-text)">{book.data.title}</span>
                <span class="font-sans text-xs ml-2" style="color: var(--color-muted)">— {book.data.author}</span>
                {book.data.tags && book.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-1.5">
                    {book.data.tags.map(tag => (
                      <a href={`/tags/${tag}`} class="tag">{tag}</a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {books.length === 0 && (
        <p class="font-serif italic py-4" style="color: var(--color-subtle)">The shelves are bare for now.</p>
      )}
    </div>
  </div>
</Site>
