---
import Site from '../../layouts/Site.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';
import { sortByDate, filterDrafts } from '../../lib/utils';

const allLogs = await getCollection('logs');
const logs = sortByDate(filterDrafts(allLogs));
---

<Site
  title="Logs"
  description="A reverse-chronological record of life. Short updates, no conclusions."
>
  <PageHeader
    title="Log"
    description="A reverse-chronological record of life. Short updates, no conclusions."
  />

  <section class="log-section">
    <div class="log-container">

      {logs.length === 0 && (
        <p class="empty-state">Nothing logged yet.</p>
      )}

      <ul class="log-list">
        {logs.map((log, index) => (
          <li
            class="log-entry"
            style={`animation-delay:${index * 0.06}s`}
          >

            <div class="log-date">
              <span class="month">
                {log.data.date.toLocaleString('en', { month: 'short' })}
              </span>

              <span class="year">
                {log.data.date.getFullYear()}
              </span>
            </div>

            <div class="log-content">

              <a
                href={`/logs/${log.slug}`}
                class="log-title"
              >
                {log.data.title}
              </a>

              {log.data.description && (
                <p class="log-description">
                  {log.data.description}
                </p>
              )}

              {log.data.tags && log.data.tags.length > 0 && (
                <div class="log-tags">
                  {log.data.tags.map(tag => (
                    <a href={`/tags/${tag}`} class="tag-link">
                      {tag}
                    </a>
                  ))}
                </div>
              )}

            </div>

          </li>
        ))}
      </ul>

    </div>
  </section>
</Site>

<style>
  .log-section {
    padding: 1.5rem 1.75rem 8rem;
  }

  .log-container {
    max-width: 760px;
    margin: 0 auto;
  }

  .empty-state {
    padding: 3rem 0;

    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;

    color: var(--color-subtle);
    opacity: 0.72;
  }

  .log-list {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }

  /* subtle vertical timeline */
  .log-list::before {
    content: "";
    position: absolute;
    left: 73px;
    top: 0;
    bottom: 0;
    width: 1px;
    background:
      linear-gradient(
        to bottom,
        transparent,
        var(--color-border),
        transparent
      );
    opacity: 0.7;
  }

  .log-entry {
    position: relative;

    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 2.5rem;

    padding: 2rem 0;

    opacity: 0;
    transform: translateY(8px);

    animation: fadeUp 0.55s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .log-entry::after {
    content: "";
    position: absolute;
    left: 69px;
    top: 2.65rem;

    width: 8px;
    height: 8px;
    border-radius: 999px;

    background: var(--color-bg);
    border: 1px solid var(--color-muted);

    z-index: 2;

    transition:
      transform 0.25s ease,
      background 0.25s ease,
      border-color 0.25s ease;
  }

  .log-entry:hover::after {
    transform: scale(1.4);
    background: var(--color-heading);
    border-color: var(--color-heading);
  }

  .log-date {
    text-align: right;
    padding-top: 0.1rem;
  }

  .month {
    display: block;

    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1;

    color: var(--color-muted);
  }

  .year {
    display: block;

    margin-top: 0.38rem;

    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.08em;

    color: var(--color-muted);
    opacity: 0.45;
  }

  .log-content {
    padding-right: 1rem;
  }

  .log-title {
    display: inline-block;

    font-family: var(--font-serif);
    font-size: 1.08rem;
    font-weight: 500;
    line-height: 1.75;
    letter-spacing: -0.01em;

    color: var(--color-heading);
    text-decoration: none;

    transition:
      opacity 0.25s ease,
      transform 0.25s ease,
      letter-spacing 0.25s ease;
  }

  .log-title:hover {
    opacity: 0.58;
    transform: translateX(3px);
    letter-spacing: 0.005em;
  }

  .log-description {
    margin-top: 0.55rem;

    max-width: 38rem;

    font-family: var(--font-serif);
    font-size: 0.99rem;
    line-height: 1.95;

    color: var(--color-subtle);

    text-wrap: pretty;
  }

  .log-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;

    margin-top: 1.1rem;
  }
  .tag-link {
    display: inline-flex;
    align-items: center;

    padding: 0.36rem 0.72rem;

    border-radius: 999px;
    border: 1px solid var(--color-border);

    background: rgba(127,127,127,0.04);

    font-family: var(--font-sans);
    font-size: 0.71rem;
    letter-spacing: 0.04em;

    color: var(--color-subtle);
    text-decoration: none;

    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .tag-link:hover {
    transform: translateY(-1px);

    border-color: var(--color-muted);
    background: rgba(127,127,127,0.07);

    color: var(--color-heading);
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 720px) {

    .log-section {
      padding: 1rem 1.2rem 6rem;
    }

    .log-list::before {
      left: 58px;
    }

    .log-entry {
      grid-template-columns: 56px 1fr;
      gap: 1.4rem;

      padding: 1.6rem 0;
    }

    .log-entry::after {
      left: 54px;
      top: 2.2rem;

      width: 7px;
      height: 7px;
    }

    .month {
      font-size: 0.64rem;
      letter-spacing: 0.15em;
    }

    .year {
      font-size: 0.68rem;
    }

    .log-title {
      font-size: 1rem;
      line-height: 1.7;
    }

    .log-description {
      font-size: 0.94rem;
      line-height: 1.8;
    }

    .tag-link {
      font-size: 0.68rem;
    }
  }
</style>