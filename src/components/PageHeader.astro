---
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---

<div class="max-w-2xl mx-auto px-5 pt-12 pb-8 md:pt-16 md:pb-10">
  <h1 class="font-serif text-2xl md:text-3xl font-semibold tracking-tight mb-3"
      style="color: var(--color-heading)">
    {title}
  </h1>
  {description && (
    <p class="font-serif text-base italic leading-relaxed" style="color: var(--color-subtle)">
      {description}
    </p>
  )}
  <hr class="divider mt-8" />
</div>
