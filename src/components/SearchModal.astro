---
---

<div
  id="search-overlay"
  class="hidden fixed inset-0 z-50 items-start justify-center pt-24 px-5"
  style="background-color: rgba(28, 25, 23, 0.4)"
  role="dialog"
  aria-modal="true"
  aria-label="Site search"
>
  <div
    class="w-full max-w-lg"
    style="background-color: var(--color-bg); border: 1px solid var(--color-border); border-radius: 2px;"
  >
    <!-- Search input row -->
    <div style="display: flex; align-items: center; gap: 10px; padding: 13px 16px; border-bottom: 1px solid var(--color-border);">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--color-muted); flex-shrink: 0;" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder="Search writings, logs, ideas…"
        autocomplete="off"
        spellcheck="false"
        style="border: none; outline: none; background: transparent; font-family: 'DM Sans', sans-serif; font-size: 15px; color: var(--color-text); flex: 1; padding: 0;"
      />
      <kbd style="font-size: 11px; color: var(--color-muted); border: 1px solid var(--color-border); border-radius: 2px; padding: 2px 6px; font-family: 'DM Sans', sans-serif; flex-shrink: 0;">Esc</kbd>
    </div>

    <!-- Results list -->
    <div id="search-results" style="max-height: 400px; overflow-y: auto;"></div>

    <!-- Keyboard hints footer -->
    <div style="padding: 8px 16px; border-top: 1px solid var(--color-border); display: flex; gap: 16px;">
      <span style="font-size: 12px; color: var(--color-muted); display: flex; align-items: center; gap: 5px;">
        <kbd style="border: 1px solid var(--color-border); border-radius: 2px; padding: 1px 5px; font-size: 11px; font-family: 'DM Sans', sans-serif; color: var(--color-subtle);">↑↓</kbd> navigate
      </span>
      <span style="font-size: 12px; color: var(--color-muted); display: flex; align-items: center; gap: 5px;">
        <kbd style="border: 1px solid var(--color-border); border-radius: 2px; padding: 1px 5px; font-size: 11px; font-family: 'DM Sans', sans-serif; color: var(--color-subtle);">↵</kbd> open
      </span>
      <span style="font-size: 12px; color: var(--color-muted); display: flex; align-items: center; gap: 5px;">
        <kbd style="border: 1px solid var(--color-border); border-radius: 2px; padding: 1px 5px; font-size: 11px; font-family: 'DM Sans', sans-serif; color: var(--color-subtle);">Esc</kbd> close
      </span>
    </div>
  </div>
</div>

<style>
  #search-results a {
    display: block;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    outline: none;
  }
  #search-results a:last-child {
    border-bottom: none;
  }
  #search-results a:hover,
  #search-results a:focus,
  #search-results a[data-active] {
    background-color: var(--color-surface);
  }
  #search-results .r-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 5px;
  }
  #search-results .r-tag {
    font-size: 0.7rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2em 0.65em;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    color: var(--color-subtle);
  }
  #search-results .r-title {
    font-family: 'Lora', serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--color-heading);
    line-height: 1.4;
    margin-bottom: 3px;
  }
  #search-results .r-excerpt {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.55;
  }
  #search-results mark {
    background: transparent;
    color: var(--color-text);
    font-weight: 500;
  }
  #search-results .r-empty {
    padding: 28px 16px;
    font-size: 14px;
    color: var(--color-muted);
    text-align: center;
    font-family: 'DM Sans', sans-serif;
  }

  /* Hide browser default search cancel button */
  #search-input::-webkit-search-cancel-button { display: none; }
</style>

<script>
  const overlay    = document.getElementById('search-overlay');
  const input      = document.getElementById('search-input') as HTMLInputElement;
  const resultsEl  = document.getElementById('search-results');
  const searchToggle = document.getElementById('search-toggle');

  // Section label map — matches your content folder names → URL paths
  const SECTION_LABELS: Record<string, string> = {
    writings:  'Writing',
    logs:      'Log',
    ideas:     'Ideas',
    bookshelf: 'Bookshelf',
    quotes:    'Quotes',
    links:     'Links',
    problems:  'Problems',
  };

  let pagefind: any = null;
  let activeIndex = -1;
  let currentLinks: HTMLAnchorElement[] = [];

  // ── Load headless Pagefind once ───────────────────────────────────────────
  async function loadPagefind() {
    if (pagefind) return pagefind;
    // @ts-ignore — pagefind is generated at build time
    pagefind = await import('/pagefind/pagefind.js');
    await pagefind.options({ excerptLength: 22 });
    return pagefind;
  }

  // ── Search ────────────────────────────────────────────────────────────────
  let debounceTimer: ReturnType<typeof setTimeout>;

  async function runSearch(query: string) {
    clearTimeout(debounceTimer);

    if (!query.trim()) {
      resultsEl!.innerHTML = '';
      activeIndex = -1;
      currentLinks = [];
      return;
    }

    debounceTimer = setTimeout(async () => {
      const pf = await loadPagefind();
      const search = await pf.debouncedSearch(query);
      if (!search) return; // stale / superseded query

      const top = search.results.slice(0, 8);
      const data = await Promise.all(top.map((r: any) => r.data()));
      renderResults(data);
    }, 150);
  }

  // ── Render results ────────────────────────────────────────────────────────
  function renderResults(results: any[]) {
    activeIndex = -1;

    if (!results.length) {
      resultsEl!.innerHTML = `<p class="r-empty">No results — try a different term.</p>`;
      currentLinks = [];
      return;
    }

    resultsEl!.innerHTML = results.map((r, i) => {
      const tag     = deriveTag(r.url);
      const title   = r.meta?.title ?? r.url;
      const excerpt = r.excerpt ?? '';
      return `
        <a href="${esc(r.url)}" data-index="${i}">
          <div class="r-meta">
            ${tag ? `<span class="r-tag">${esc(tag)}</span>` : ''}
          </div>
          <p class="r-title">${esc(title)}</p>
          <p class="r-excerpt">${excerpt}</p>
        </a>`;
    }).join('');

    currentLinks = Array.from(resultsEl!.querySelectorAll('a'));
  }

  function deriveTag(url: string): string {
    const seg = url.split('/').filter(Boolean)[0] ?? '';
    return SECTION_LABELS[seg.toLowerCase()] ?? '';
  }

  function esc(str: string): string {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ── Keyboard navigation ───────────────────────────────────────────────────
  function setActive(idx: number) {
    currentLinks.forEach(l => l.removeAttribute('data-active'));
    if (idx < 0 || idx >= currentLinks.length) { activeIndex = -1; return; }
    activeIndex = idx;
    currentLinks[idx].setAttribute('data-active', '');
    currentLinks[idx].scrollIntoView({ block: 'nearest' });
  }

  // ── Open / close ──────────────────────────────────────────────────────────
  function openSearch() {
    overlay?.classList.remove('hidden');
    overlay?.classList.add('flex');
    loadPagefind(); // warm up in background
    requestAnimationFrame(() => input?.focus());
  }

  function closeSearch() {
    overlay?.classList.add('hidden');
    overlay?.classList.remove('flex');
    if (input) input.value = '';
    if (resultsEl) resultsEl.innerHTML = '';
    activeIndex = -1;
    currentLinks = [];
  }

  // ── Event listeners ───────────────────────────────────────────────────────
  searchToggle?.addEventListener('click', openSearch);

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeSearch();
  });

  input?.addEventListener('input', (e) => {
    runSearch((e.target as HTMLInputElement).value);
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); setActive(activeIndex + 1); }
    if (e.key === 'ArrowUp')   { e.preventDefault(); setActive(activeIndex - 1); }
    if (e.key === 'Enter' && activeIndex >= 0) {
      e.preventDefault();
      currentLinks[activeIndex]?.click();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });
</script>